{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://d2h5.game/schemas/sub-area.json",
  "title": "Sub-Area Definition",
  "description": "Sub-area (map zone) definition with waves and encounters",
  "type": "object",
  "required": ["id", "name", "actId", "areaLevel", "waves", "hasBoss", "challenge", "lootTable"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^areas/[a-z0-9-]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "actId": {
      "type": "string",
      "pattern": "^acts/act[1-5]$"
    },
    "areaLevel": {
      "type": "integer",
      "minimum": 1
    },
    "monsterPool": {
      "type": "array",
      "items": { "$ref": "#/$defs/monsterPoolEntry" },
      "description": "Weighted monster archetype pool available to this area"
    },
    "waves": {
      "type": "array",
      "items": { "$ref": "#/$defs/wave" },
      "minItems": 1
    },
    "hasBoss": {
      "type": "boolean"
    },
    "bossEncounter": {
      "$ref": "#/$defs/encounter"
    },
    "chapterBoss": {
      "$ref": "#/$defs/chapterBoss"
    },
    "challenge": {
      "$ref": "#/$defs/challenge",
      "description": "Manual challenge wave-generation rules."
    },
    "difficulty": {
      "$ref": "#/$defs/difficulty",
      "description": "JSON-driven difficulty tuning for map progression."
    },
    "lootTable": {
      "type": "string",
      "description": "Loot table ID"
    },
    "flavor": {
      "type": "string",
      "description": "Short English flavor text shown on entry"
    }
  },
  "$defs": {
    "monsterPoolEntry": {
      "type": "object",
      "required": ["archetypeId", "weight"],
      "additionalProperties": false,
      "properties": {
        "archetypeId": { "type": "string" },
        "weight": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "chapterBoss": {
      "type": "object",
      "description": "Act-ending boss gate appended after generated challenge waves.",
      "required": ["archetypeId", "hp", "atk", "def", "skills", "dropTable"],
      "additionalProperties": false,
      "properties": {
        "archetypeId": { "type": "string" },
        "hp": {
          "type": "integer",
          "minimum": 1,
          "description": "Base HP before applying elite-config.chapterBossHpMultiplier."
        },
        "atk":{ "type": "integer", "minimum": 1 },
        "def": { "type": "integer", "minimum": 0 },
        "skills": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "dropTable": { "type": "string" }
      }
    },
    "challenge": {
      "type": "object",
      "required": ["monsterCount", "rotation", "manualFinalEliteWaves"],
      "additionalProperties": false,
      "properties": {
        "monsterCount": {
          "type": "object",
          "required": ["min", "max"],
          "additionalProperties": false,
          "properties": {
            "min": {
              "type": "integer",
              "minimum": 8,
              "maximum": 20,
              "description": "Minimum monsters in each generated non-boss challenge wave."
            },
            "max": {
              "type": "integer",
              "minimum": 8,
              "maximum": 20,
              "description": "Maximum monsters in each generated non-boss challenge wave."
            }
          }
        },
        "rotation": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["trash", "elite", "boss", "treasure", "shrine"]
          },
          "minItems": 1,
          "description": "Cyclic wave-kind fallback pattern for synthetic challenge waves."
        },
        "manualFinalEliteWaves": {
          "type": "integer",
          "const": 2,
          "description": "Manual challenges force the final two non-boss waves to elites."
        },
        "appendChapterBoss": {
          "type": "boolean",
          "description": "Append chapterBoss after authored/fallback non-boss waves when present."
        }
      }
    },
    "difficulty": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "finaleBand": {
          "type": "string",
          "enum": ["none", "penultimate", "final"],
          "description": "Player-facing difficulty band for late-act build checks."
        },
        "monsterLevelBonus": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5,
          "description": "Additional effective monster levels applied by the challenge planner."
        }
      }
    },
    "wave": {
      "type": "object",
      "required": ["id", "type"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["trash", "elite", "boss", "treasure", "shrine"]
        },
        "encounters": {
          "type": "array",
          "items": { "$ref": "#/$defs/encounter" }
        },
        "lootTable": { "type": "string" }
      }
    },
    "encounter": {
      "type": "object",
      "required": ["id", "monsters", "level"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "monsters": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["archetypeId"],
            "additionalProperties": false,
            "properties": {
              "archetypeId": { "type": "string" },
              "count": { "type": "integer", "minimum": 1, "maximum": 20 },
              "countMin": { "type": "integer", "minimum": 1, "maximum": 20 },
              "countMax": { "type": "integer", "minimum": 1, "maximum": 20 },
              "elite": { "type": "boolean" },
              "boss": { "type": "boolean" }
            }
          },
          "minItems": 1
        },
        "level": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
