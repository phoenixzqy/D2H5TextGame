{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://d2h5.game/schemas/rarity-rules.json",
  "type": "object",
  "required": [
    "id",
    "tiers"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "const": "config/rarity-rules"
    },
    "tiers": {
      "type": "object",
      "required": [
        "normal",
        "magic",
        "rare",
        "set",
        "unique"
      ],
      "additionalProperties": false,
      "properties": {
        "normal": {
          "$ref": "#/$defs/rarityTier"
        },
        "magic": {
          "$ref": "#/$defs/rarityTier"
        },
        "rare": {
          "$ref": "#/$defs/rarityTier"
        },
        "set": {
          "$ref": "#/$defs/rarityTier"
        },
        "unique": {
          "$ref": "#/$defs/rarityTier"
        }
      }
    }
  },
  "$defs": {
    "range": {
      "type": "object",
      "required": [
        "min",
        "max"
      ],
      "additionalProperties": false,
      "properties": {
        "min": {
          "type": "integer",
          "minimum": 0
        },
        "max": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "rarityTier": {
      "type": "object",
      "required": [
        "dropWeight",
        "affixCount"
      ],
      "additionalProperties": false,
      "properties": {
        "dropWeight": {
          "type": "number",
          "minimum": 0
        },
        "affixCount": {
          "type": "object",
          "required": [
            "prefix",
            "suffix"
          ],
          "additionalProperties": false,
          "properties": {
            "prefix": {
              "$ref": "#/$defs/range"
            },
            "suffix": {
              "$ref": "#/$defs/range"
            },
            "total": {
              "$ref": "#/$defs/range"
            }
          }
        }
      }
    }
  }
}
