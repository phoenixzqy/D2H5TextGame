{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://d2h5.game/schemas/rune.json",
  "title": "Rune Definition",
  "description": "Socketable rune definition",
  "type": "object",
  "required": ["id", "name", "tier"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^runes/[a-z0-9-]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "tier": {
      "type": "integer",
      "minimum": 1,
      "maximum": 33,
      "description": "Rune tier (1-33 in D2)"
    },
    "weaponEffect": {
      "$ref": "#/$defs/runeEffect",
      "description": "Effect when socketed in weapon"
    },
    "armorEffect": {
      "$ref": "#/$defs/runeEffect",
      "description": "Effect when socketed in armor/helm"
    },
    "shieldEffect": {
      "$ref": "#/$defs/runeEffect",
      "description": "Effect when socketed in shield"
    }
  },
  "$defs": {
    "runeEffect": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "coreStats": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "strength": { "type": "integer" },
            "dexterity": { "type": "integer" },
            "vitality": { "type": "integer" },
            "energy": { "type": "integer" }
          }
        },
        "resistances": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "fire": { "type": "number" },
            "cold": { "type": "number" },
            "lightning": { "type": "number" },
            "poison": { "type": "number" },
            "arcane": { "type": "number" },
            "physical": { "type": "number" }
          }
        },
        "statMods": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "life": { "type": "number" },
            "mana": { "type": "number" },
            "attack": { "type": "number" },
            "defense": { "type": "number" },
            "attackSpeed": { "type": "number" },
            "critChance": { "type": "number" },
            "critDamage": { "type": "number" },
            "physDodge": { "type": "number" },
            "magicDodge": { "type": "number" },
            "magicFind": { "type": "number" },
            "goldFind": { "type": "number" }
          }
        }
      }
    }
  }
}
