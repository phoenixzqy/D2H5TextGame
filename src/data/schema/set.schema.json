{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://d2h5.game/schemas/set.json",
  "title": "Set Definition",
  "description": "Set (green) item collection definition",
  "type": "object",
  "required": ["id", "name", "items", "bonuses"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^sets/[a-z0-9-]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "items": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 2,
      "description": "Item IDs in this set"
    },
    "pieces": {
      "type": "array",
      "description": "Concrete set pieces that can drop and be equipped",
      "items": {
        "type": "object",
        "required": ["id", "setId", "name", "baseId", "reqLevel", "stats"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^sets/[a-z0-9-]+/[a-z0-9-]+$" },
          "setId": { "type": "string", "pattern": "^sets/[a-z0-9-]+$" },
          "name": { "type": "string", "minLength": 1 },
          "baseId": { "type": "string" },
          "reqLevel": { "type": "integer", "minimum": 1 },
          "qlvl": { "type": "integer", "minimum": 1 },
          "weight": { "type": "number", "exclusiveMinimum": 0 },
          "stats": { "$ref": "#/$defs/setBonus" },
          "flavor": { "type": "string" }
        }
      }
    },
    "bonuses": {
      "type": "object",
      "patternProperties": {
        "^[0-9]+$": {
          "$ref": "#/$defs/setBonus"
        }
      },
      "description": "Set bonuses keyed by number of pieces equipped"
    }
  },
  "$defs": {
    "setBonus": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "coreStats": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "strength": { "$ref": "#/$defs/statValue" },
            "dexterity": { "$ref": "#/$defs/statValue" },
            "vitality": { "$ref": "#/$defs/statValue" },
            "energy": { "$ref": "#/$defs/statValue" }
          }
        },
        "resistances": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "fire": { "$ref": "#/$defs/statValue" },
            "cold": { "$ref": "#/$defs/statValue" },
            "lightning": { "$ref": "#/$defs/statValue" },
            "poison": { "$ref": "#/$defs/statValue" },
            "arcane": { "$ref": "#/$defs/statValue" },
            "physical": { "$ref": "#/$defs/statValue" },
            "all": { "$ref": "#/$defs/statValue" }
          }
        },
        "statMods": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "life": { "$ref": "#/$defs/statValue" },
            "mana": { "$ref": "#/$defs/statValue" },
            "attack": { "$ref": "#/$defs/statValue" },
            "defense": { "$ref": "#/$defs/statValue" },
            "attackSpeed": { "$ref": "#/$defs/statValue" },
            "critChance": { "$ref": "#/$defs/statValue" },
            "critDamage": { "$ref": "#/$defs/statValue" },
            "physDodge": { "$ref": "#/$defs/statValue" },
            "magicDodge": { "$ref": "#/$defs/statValue" },
            "magicFind": { "$ref": "#/$defs/statValue" },
            "goldFind": { "$ref": "#/$defs/statValue" }
          }
        },
        "grantsSkills": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "statValue": {
      "oneOf": [
        { "type": "number" },
        {
          "type": "object",
          "required": ["roll", "min", "max"],
          "additionalProperties": false,
          "properties": {
            "roll": { "type": "string", "minLength": 1 },
            "min": { "type": "number" },
            "max": { "type": "number" },
            "step": { "type": "number", "exclusiveMinimum": 0 }
          }
        }
      ]
    }
  }
}
