{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://d2h5.game/schemas/merc.json",
  "title": "Mercenary Definition",
  "description": "Mercenary archetype definition",
  "type": "object",
  "required": ["id", "name", "archetype", "rarity", "baseStats", "skills", "reqLevel", "classRef", "signatureSkillId", "starUpgradeCurve", "portraitAsset", "iconAsset"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^mercs/[a-z0-9-]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "classRef": {
      "type": "string",
      "description": "Class/archetype reference — superset of player classes plus D2 merc archetypes",
      "enum": ["amazon", "assassin", "barbarian", "druid", "necromancer", "paladin", "sorceress", "rogue", "desert-merc", "iron-wolf", "militia", "thief", "acolyte"]
    },
    "archetype": {
      "type": "string",
      "description": "Mercenary class/type"
    },
    "rarity": {
      "type": "string",
      "enum": ["R", "SR", "SSR"]
    },
    "signatureSkillId": {
      "type": "string",
      "description": "Signature skill ID (gains +1 rank per star)"
    },
    "baseStats": {
      "$ref": "#/$defs/baseStats"
    },
    "starUpgradeCurve": {
      "$ref": "#/$defs/starUpgradeCurve"
    },
    "portraitAsset": {
      "type": "string",
      "description": "Path to portrait image under public/"
    },
    "iconAsset": {
      "type": "string",
      "description": "Path to icon image under public/"
    },
    "skills": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "Skill IDs"
    },
    "comboOrder": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Default skill combo order"
    },
    "reqLevel": {
      "type": "integer",
      "minimum": 1
    },
    "flavor": {
      "type": "string",
      "description": "Flavor text"
    }
  },
  "$defs": {
    "baseStats": {
      "type": "object",
      "required": ["strength", "dexterity", "vitality", "energy"],
      "additionalProperties": false,
      "properties": {
        "strength": { "type": "integer", "minimum": 1 },
        "dexterity": { "type": "integer", "minimum": 1 },
        "vitality": { "type": "integer", "minimum": 1 },
        "energy": { "type": "integer", "minimum": 1 }
      }
    },
    "starUpgradeCurve": {
      "type": "object",
      "required": ["1", "2", "3", "4", "5", "6"],
      "additionalProperties": false,
      "properties": {
        "1": { "type": "number", "description": "Stat multiplier at 1★", "minimum": 1.0 },
        "2": { "type": "number", "description": "Stat multiplier at 2★", "minimum": 1.0 },
        "3": { "type": "number", "description": "Stat multiplier at 3★", "minimum": 1.0 },
        "4": { "type": "number", "description": "Stat multiplier at 4★", "minimum": 1.0 },
        "5": { "type": "number", "description": "Stat multiplier at 5★", "minimum": 1.0 },
        "6": { "type": "number", "description": "Stat multiplier at 6★", "minimum": 1.0 }
      }
    }
  }
}
