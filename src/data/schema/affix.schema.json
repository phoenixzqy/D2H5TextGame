{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://d2h5.game/schemas/affix.json",
  "title": "Affix Definition",
  "type": "object",
  "required": [
    "id",
    "kind",
    "appliesTo",
    "stat",
    "tiers",
    "rarityWeights",
    "i18nKey"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^affix\\.[a-z0-9.-]+$"
    },
    "kind": {
      "type": "string",
      "enum": [
        "prefix",
        "suffix"
      ]
    },
    "appliesTo": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "weapon",
          "armor",
          "jewelry",
          "charm"
        ]
      }
    },
    "stat": {
      "type": "string",
      "enum": [
        "attack",
        "life",
        "mana",
        "defense",
        "critChance",
        "critDamage",
        "physDodge",
        "magicDodge",
        "fireRes",
        "coldRes",
        "lightningRes",
        "poisonRes",
        "arcaneRes",
        "physicalRes"
      ]
    },
    "tiers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "ilvlMin",
          "ilvlMax",
          "valueMin",
          "valueMax"
        ],
        "additionalProperties": false,
        "properties": {
          "ilvlMin": {
            "type": "integer",
            "minimum": 1
          },
          "ilvlMax": {
            "type": "integer",
            "minimum": 1
          },
          "valueMin": {
            "type": "integer"
          },
          "valueMax": {
            "type": "integer"
          }
        }
      }
    },
    "rarityWeights": {
      "type": "object",
      "required": [
        "magic",
        "rare"
      ],
      "additionalProperties": false,
      "properties": {
        "magic": {
          "type": "number",
          "minimum": 0
        },
        "rare": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "i18nKey": {
      "type": "string"
    }
  }
}
