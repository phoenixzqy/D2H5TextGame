{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://d2h5.game/schemas/unique.json",
  "title": "Unique Item Definition",
  "description": "Unique (gold) item definition",
  "type": "object",
  "required": ["id", "name", "baseId", "reqLevel", "stats"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^items/unique/[a-z0-9-]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "baseId": {
      "type": "string",
      "description": "Reference to item base"
    },
    "reqLevel": {
      "type": "integer",
      "minimum": 1
    },
    "qlvl": {
      "type": "integer",
      "minimum": 1,
      "description": "Minimum item level for this unique to drop"
    },
    "weight": {
      "type": "number",
      "exclusiveMinimum": 0,
      "description": "Relative selection weight among eligible uniques for the same base"
    },
    "flavor": {
      "type": "string",
      "description": "Flavor text"
    },
    "stats": {
      "$ref": "#/$defs/stats"
    }
  },
  "$defs": {
    "stats": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "coreStats": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "strength": { "$ref": "#/$defs/statValue" },
            "dexterity": { "$ref": "#/$defs/statValue" },
            "vitality": { "$ref": "#/$defs/statValue" },
            "energy": { "$ref": "#/$defs/statValue" }
          }
        },
        "resistances": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "fire": { "$ref": "#/$defs/statValue" },
            "cold": { "$ref": "#/$defs/statValue" },
            "lightning": { "$ref": "#/$defs/statValue" },
            "poison": { "$ref": "#/$defs/statValue" },
            "arcane": { "$ref": "#/$defs/statValue" },
            "physical": { "$ref": "#/$defs/statValue" },
            "all": { "$ref": "#/$defs/statValue" }
          }
        },
        "statMods": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "life": { "$ref": "#/$defs/statValue" },
            "mana": { "$ref": "#/$defs/statValue" },
            "attack": { "$ref": "#/$defs/statValue" },
            "defense": { "$ref": "#/$defs/statValue" },
            "attackSpeed": { "$ref": "#/$defs/statValue" },
            "critChance": { "$ref": "#/$defs/statValue" },
            "critDamage": { "$ref": "#/$defs/statValue" },
            "physDodge": { "$ref": "#/$defs/statValue" },
            "magicDodge": { "$ref": "#/$defs/statValue" },
            "magicFind": { "$ref": "#/$defs/statValue" },
            "goldFind": { "$ref": "#/$defs/statValue" }
          }
        },
        "grantsSkills": {
          "type": "array",
          "items": { "type": "string" }
        },
        "damageBonus": {
          "type": "object",
          "required": ["min", "max", "breakdown"],
          "additionalProperties": false,
          "properties": {
            "min": { "$ref": "#/$defs/statValue" },
            "max": { "$ref": "#/$defs/statValue" },
            "value": { "$ref": "#/$defs/statValue" },
            "breakdown": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "physical": { "$ref": "#/$defs/statValue" },
                "fire": { "$ref": "#/$defs/statValue" },
                "cold": { "$ref": "#/$defs/statValue" },
                "lightning": { "$ref": "#/$defs/statValue" },
                "arcane": { "$ref": "#/$defs/statValue" },
                "poison": { "$ref": "#/$defs/statValue" },
                "thorns": { "$ref": "#/$defs/statValue" }
              }
            }
          }
        }
      }
    },
    "statValue": {
      "oneOf": [
        { "type": "number" },
        {
          "type": "object",
          "required": ["roll", "min", "max"],
          "additionalProperties": false,
          "properties": {
            "roll": { "type": "string", "minLength": 1 },
            "min": { "type": "number" },
            "max": { "type": "number" },
            "step": { "type": "number", "exclusiveMinimum": 0 }
          }
        }
      ]
    }
  }
}
